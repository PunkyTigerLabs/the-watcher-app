{
  "expo": {
    "name": "The Watcher",
    "slug": "the-watcher",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "thewatcher",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080B12"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.punkytiger.thewatcher"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080B12"
      },
      "package": "com.punkytiger.thewatcher"
    }
  }
}

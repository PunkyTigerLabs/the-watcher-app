# ============================================
# THE WATCHER — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your API keys
# NEVER commit the .env file to git

# Server
PORT=3000
NODE_ENV=development

# Blockchain API Keys (all free tier)
# Register at: https://etherscan.io/apis
ETHERSCAN_API_KEY=your_etherscan_key_here

# Register at: https://basescan.org/apis
BASESCAN_API_KEY=your_basescan_key_here

# Register at: https://www.trongrid.io/
TRONGRID_API_KEY=your_trongrid_key_here

# News & Sentiment
# Register at: https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here

# AI Analyst (optional — pay per use ~$5-10/month)
# Register at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# App Security
# Generate a random string for Sprint 1 API key auth
WATCHER_API_KEY=change_this_to_a_random_string

# Feature Flags
ENABLE_ANALYST=false
ENABLE_PUSH_NOTIFICATIONS=false
